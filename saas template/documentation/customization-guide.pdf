<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Flowdesk — The all-in-one project management platform that helps teams ship faster, collaborate better, and track everything that matters." />
  <title>Flowdesk — Manage Work, Ship Faster</title>
  <link rel="icon" href="images/logo.svg" type="image/svg+xml" />
  <link rel="stylesheet" href="css/variables.css" />
  <link rel="stylesheet" href="css/style.css" />
  <link rel="stylesheet" href="css/responsive.css" />
  <script src="js/theme.js" defer></script>
</head>
<body>

  <!-- ============ NAVIGATION ============ -->
  <nav class="nav" role="navigation" aria-label="Main navigation">
    <div class="nav-inner">
      <a href="index.html" class="nav-logo">
        <div class="nav-logo-icon">⚡</div>
        Flowdesk
      </a>

      <div class="nav-links" role="list">
        <a href="features.html" class="nav-link" role="listitem">Features</a>
        <a href="pricing.html" class="nav-link" role="listitem">Pricing</a>
        <a href="#testimonials" class="nav-link" role="listitem">Customers</a>
        <a href="contact.html" class="nav-link" role="listitem">Contact</a>
      </div>

      <div class="nav-actions">
        <a href="login.html" class="btn btn-secondary btn-sm">Sign in</a>
        <a href="signup.html" class="btn btn-primary btn-sm">Start free trial</a>
        <button class="nav-mobile-toggle" aria-label="Open menu" aria-expanded="false">
          <span></span>
          <span></span>
          <span></span>
        </button>
      </div>
    </div>
  </nav>

  <main>
    <!-- ============ HERO ============ -->
    <section class="hero">
      <div class="hero-bg"></div>
      <div class="hero-grid-bg"></div>

      <div class="container">
        <div class="hero-content">
          <div class="hero-eyebrow">
            <span class="badge badge-primary">✨ New: AI task suggestions</span>
          </div>

          <h1 class="hero-title">
            Your team's work,<br />
            <span class="text-gradient">finally in flow.</span>
          </h1>

          <p class="hero-subtitle">
            Flowdesk brings tasks, docs, timelines, and your team into one connected workspace. Stop context-switching. Start shipping.
          </p>

          <div class="hero-actions">
            <a href="signup.html" class="btn btn-primary btn-lg">
              Get started free
              <span>→</span>
            </a>
            <a href="features.html" class="btn btn-secondary btn-lg">
              See how it works
            </a>
          </div>

          <div class="hero-trust">
            <div class="hero-avatars">
              <div class="hero-avatar" style="background: linear-gradient(135deg, #6366F1, #8B5CF6);">A</div>
              <div class="hero-avatar" style="background: linear-gradient(135deg, #0891B2, #06B6D4);">M</div>
              <div class="hero-avatar" style="background: linear-gradient(135deg, #059669, #10B981);">S</div>
              <div class="hero-avatar" style="background: linear-gradient(135deg, #DC2626, #EF4444);">J</div>
              <div class="hero-avatar" style="background: linear-gradient(135deg, #D97706, #F59E0B);">R</div>
            </div>
            <p class="hero-trust-text">Trusted by <strong style="color:var(--color-text-primary)">12,000+</strong> teams worldwide</p>
          </div>
        </div>
      </div>

      <!-- Dashboard Mockup -->
      <div class="hero-visual">
        <div class="dashboard-mockup">
          <div class="mockup-topbar">
            <div class="mockup-dots">
              <div class="mockup-dot"></div>
              <div class="mockup-dot"></div>
              <div class="mockup-dot"></div>
            </div>
            <div class="mockup-url">app.flowdesk.io/dashboard</div>
          </div>
          <div class="mockup-body">
            <div class="mockup-sidebar">
              <div class="mockup-nav-item active">
                <span class="icon">⊞</span> Dashboard
              </div>
              <div class="mockup-nav-item">
                <span class="icon">✓</span> Tasks
              </div>
              <div class="mockup-nav-item">
                <span class="icon">📋</span> Projects
              </div>
              <div class="mockup-nav-item">
                <span class="icon">📅</span> Timeline
              </div>
              <div class="mockup-nav-item">
                <span class="icon">💬</span> Inbox
              </div>
              <div class="mockup-nav-item">
                <span class="icon">📊</span> Reports
              </div>
              <div class="mockup-nav-item" style="margin-top:auto;">
                <span class="icon">⚙</span> Settings
              </div>
            </div>
            <div class="mockup-main">
              <div class="mockup-stats">
                <div class="mockup-stat">
                  <div class="mockup-stat-val">48</div>
                  <div class="mockup-stat-label">Active Tasks</div>
                  <div class="mockup-stat-change">↑ 12%</div>
                </div>
                <div class="mockup-stat">
                  <div class="mockup-stat-val">6</div>
                  <div class="mockup-stat-label">Projects</div>
                  <div class="mockup-stat-change">↑ 2 new</div>
                </div>
                <div class="mockup-stat">
                  <div class="mockup-stat-val">94%</div>
                  <div class="mockup-stat-label">On Track</div>
                  <div class="mockup-stat-change">↑ 4%</div>
                </div>
              </div>
              <div class="mockup-chart-area">
                <div class="chart-bar" style="height:50%; animation-delay:0.1s;"></div>
                <div class="chart-bar" style="height:70%; animation-delay:0.15s;"></div>
                <div class="chart-bar" style="height:45%; animation-delay:0.2s;"></div>
                <div class="chart-bar" style="height:85%; animation-delay:0.25s;"></div>
                <div class="chart-bar" style="height:60%; animation-delay:0.3s;"></div>
                <div class="chart-bar" style="height:75%; animation-delay:0.35s;"></div>
                <div class="chart-bar" style="height:90%; animation-delay:0.4s;"></div>
                <div class="chart-bar" style="height:65%; animation-delay:0.45s;"></div>
              </div>
              <div class="mockup-tasks">
                <div class="mockup-task">
                  <div class="task-check done"></div>
                  Design system audit
                  <span class="task-tag tag-low">Done</span>
                </div>
                <div class="mockup-task">
                  <div class="task-check"></div>
                  API integration v2
                  <span class="task-tag tag-high">High</span>
                </div>
                <div class="mockup-task">
                  <div class="task-check"></div>
                  Q3 roadmap review
                  <span class="task-tag tag-mid">Mid</span>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Floating cards -->
        <div class="hero-float-card card-a">
          <span>✅</span>
          <div>
            <div style="font-weight:600; font-size:12px;">Sprint completed!</div>
            <div style="font-size:11px; color:var(--color-text-muted);">14 tasks shipped</div>
          </div>
        </div>

        <div class="hero-float-card card-b">
          <span style="font-size:20px;">🚀</span>
          <div>
            <div style="font-weight:600; font-size:12px;">99.9% uptime</div>
            <div style="font-size:11px; color:var(--color-text-muted);">This month</div>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ LOGOS ============ -->
    <section class="logos-section">
      <div class="container">
        <p class="logos-label">Trusted by teams at</p>
        <div class="logos-track">
          <span class="logo-item">Acecraft</span>
          <span class="logo-item">Meridian</span>
          <span class="logo-item">Stackwise</span>
          <span class="logo-item">Lunara</span>
          <span class="logo-item">Vortex</span>
          <span class="logo-item">Prismly</span>
        </div>
      </div>
    </section>

    <!-- ============ STATS ============ -->
    <section class="section">
      <div class="container">
        <div class="stats-grid" data-reveal>
          <div class="stat-item">
            <div class="stat-value" data-count="12" data-suffix="K+">0</div>
            <div class="stat-label">Teams worldwide</div>
          </div>
          <div class="stat-item">
            <div class="stat-value" data-count="98" data-suffix="%">0</div>
            <div class="stat-label">Customer satisfaction</div>
          </div>
          <div class="stat-item">
            <div class="stat-value" data-count="4.2" data-suffix="M">0</div>
            <div class="stat-label">Tasks completed</div>
          </div>
          <div class="stat-item">
            <div class="stat-value" data-count="99.9" data-suffix="%">0</div>
            <div class="stat-label">Uptime SLA</div>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ FEATURES ============ -->
    <section class="section bg-secondary" id="features">
      <div class="container">
        <div class="section-header centered" data-reveal>
          <span class="section-label">Features</span>
          <h2 class="section-title">Everything your team needs,<br /><span class="text-gradient">nothing you don't</span></h2>
          <p class="section-subtitle">Built for fast-moving teams who want clarity, not complexity. Six tools in one platform.</p>
        </div>

        <div class="features-grid">
          <div class="card feature-card" data-reveal data-delay="0">
            <div class="feature-icon feature-icon-primary">📋</div>
            <h3 class="feature-title">Smart Task Management</h3>
            <p class="feature-desc">Create, assign, and prioritize tasks in seconds. Use AI suggestions to break down big goals into manageable steps automatically.</p>
            <a href="features.html" class="feature-link">Learn more <span>→</span></a>
          </div>

          <div class="card feature-card" data-reveal data-delay="80">
            <div class="feature-icon feature-icon-accent">📅</div>
            <h3 class="feature-title">Visual Timeline</h3>
            <p class="feature-desc">Drag-and-drop Gantt-style timelines give your team a clear picture of project progress, dependencies, and deadlines at a glance.</p>
            <a href="features.html" class="feature-link">Learn more <span>→</span></a>
          </div>

          <div class="card feature-card" data-reveal data-delay="160">
            <div class="feature-icon feature-icon-success">💬</div>
            <h3 class="feature-title">Contextual Collaboration</h3>
            <p class="feature-desc">Comment directly on tasks, share files, and mention teammates — all discussion lives exactly where the work happens.</p>
            <a href="features.html" class="feature-link">Learn more <span>→</span></a>
          </div>

          <div class="card feature-card" data-reveal data-delay="0">
            <div class="feature-icon feature-icon-primary">📊</div>
            <h3 class="feature-title">Live Dashboards</h3>
            <p class="feature-desc">Build custom dashboards with drag-and-drop widgets. Track velocity, burndown, and team capacity in real time.</p>
            <a href="features.html" class="feature-link">Learn more <span>→</span></a>
          </div>

          <div class="card feature-card" data-reveal data-delay="80">
            <div class="feature-icon feature-icon-accent">🔗</div>
            <h3 class="feature-title">60+ Integrations</h3>
            <p class="feature-desc">Connect Flowdesk to Slack, GitHub, Figma, Notion, and 60+ other tools your team already uses — in a few clicks, no code needed.</p>
            <a href="features.html" class="feature-link">Learn more <span>→</span></a>
          </div>

          <div class="card feature-card" data-reveal data-delay="160">
            <div class="feature-icon feature-icon-success">🔒</div>
            <h3 class="feature-title">Enterprise Security</h3>
            <p class="feature-desc">SOC 2 Type II certified, SSO, 2FA, granular permissions, and audit logs. Your data stays yours — encrypted at rest and in transit.</p>
            <a href="features.html" class="feature-link">Learn more <span>→</span></a>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ HOW IT WORKS ============ -->
    <section class="section how-it-works" id="how-it-works">
      <div class="container">
        <div class="section-header" data-reveal>
          <span class="section-label">How it works</span>
          <h2 class="section-title">Up and running<br /><span class="text-gradient">in under 5 minutes</span></h2>
        </div>

        <div class="steps-container">
          <div class="steps-list">
            <div class="step-item active" data-reveal>
              <div class="step-number">1</div>
              <div class="step-content">
                <h3>Create your workspace</h3>
                <p>Sign up, name your workspace, and invite your team. Flowdesk auto-creates a starter project so you're not staring at a blank screen.</p>
              </div>
            </div>

            <div class="step-item" data-reveal data-delay="100">
              <div class="step-number">2</div>
              <div class="step-content">
                <h3>Add your projects &amp; tasks</h3>
                <p>Import from Trello, Asana, or start fresh. Use templates for sprints, product launches, or client work — pre-loaded with best practices.</p>
              </div>
            </div>

            <div class="step-item" data-reveal data-delay="200">
              <div class="step-number">3</div>
              <div class="step-content">
                <h3>Connect your tools</h3>
                <p>Link Slack for notifications, GitHub for PR tracking, and your calendar for deadline sync. Everything in one feed, zero fragmentation.</p>
              </div>
            </div>

            <div class="step-item" data-reveal data-delay="300">
              <div class="step-number">4</div>
              <div class="step-content">
                <h3>Ship and measure</h3>
                <p>Watch your team move. Use reports and dashboards to catch blockers early, celebrate wins, and keep every stakeholder informed.</p>
              </div>
            </div>
          </div>

          <div class="steps-visual" data-reveal data-delay="200">
            <div class="steps-screen">
              <div style="display:flex; flex-direction:column; gap:12px; height:100%;">
                <div style="display:flex; justify-content:space-between; align-items:center;">
                  <span style="font-weight:700; font-size:14px;">Q3 Launch Plan</span>
                  <span class="badge badge-success">On track</span>
                </div>
                <div style="display:flex; gap:12px; flex:1; overflow:hidden;">
                  <div style="flex:1; display:flex; flex-direction:column; gap:6px;">
                    <div style="font-size:10px; color:var(--color-text-muted); font-weight:600; text-transform:uppercase; letter-spacing:0.06em; padding-bottom:6px; border-bottom:1px solid var(--color-border);">To Do</div>
                    <div style="background:var(--color-bg-elevated); border-radius:8px; padding:10px; font-size:11px; border-left:3px solid var(--color-primary);">
                      <div style="font-weight:600; margin-bottom:4px;">API Rate Limiting</div>
                      <div style="color:var(--color-text-muted);">Backend · 3 pts</div>
                    </div>
                    <div style="background:var(--color-bg-elevated); border-radius:8px; padding:10px; font-size:11px; border-left:3px solid var(--color-accent);">
                      <div style="font-weight:600; margin-bottom:4px;">Onboarding Flow</div>
                      <div style="color:var(--color-text-muted);">Design · 5 pts</div>
                    </div>
                  </div>
                  <div style="flex:1; display:flex; flex-direction:column; gap:6px;">
                    <div style="font-size:10px; color:var(--color-text-muted); font-weight:600; text-transform:uppercase; letter-spacing:0.06em; padding-bottom:6px; border-bottom:1px solid var(--color-border);">In Progress</div>
                    <div style="background:var(--color-bg-elevated); border-radius:8px; padding:10px; font-size:11px; border-left:3px solid var(--color-warning);">
                      <div style="font-weight:600; margin-bottom:4px;">Dashboard v2</div>
                      <div style="color:var(--color-text-muted);">Frontend · 8 pts</div>
                    </div>
                  </div>
                  <div style="flex:1; display:flex; flex-direction:column; gap:6px;">
                    <div style="font-size:10px; color:var(--color-text-muted); font-weight:600; text-transform:uppercase; letter-spacing:0.06em; padding-bottom:6px; border-bottom:1px solid var(--color-border);">Done</div>
                    <div style="background:var(--color-bg-elevated); border-radius:8px; padding:10px; font-size:11px; border-left:3px solid var(--color-success); opacity:0.7;">
                      <div style="font-weight:600; margin-bottom:4px; text-decoration:line-through;">Auth system</div>
                      <div style="color:var(--color-text-muted);">Backend · 5 pts</div>
                    </div>
                    <div style="background:var(--color-bg-elevated); border-radius:8px; padding:10px; font-size:11px; border-left:3px solid var(--color-success); opacity:0.7;">
                      <div style="font-weight:600; margin-bottom:4px; text-decoration:line-through;">DB schema</div>
                      <div style="color:var(--color-text-muted);">Backend · 3 pts</div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ INTEGRATIONS ============ -->
    <section class="section">
      <div class="container">
        <div class="section-header centered" data-reveal>
          <span class="section-label">Integrations</span>
          <h2 class="section-title">Works with your<br /><span class="text-gradient">existing stack</span></h2>
          <p class="section-subtitle">Connect to the tools your team loves. No rebuilding workflows from scratch.</p>
