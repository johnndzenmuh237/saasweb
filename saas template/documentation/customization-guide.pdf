    <!-- ============ TESTIMONIALS ============ -->
    <section class="section bg-secondary" id="testimonials">
      <div class="container">
        <div class="section-header centered" data-reveal>
          <span class="section-label">Testimonials</span>
          <h2 class="section-title">Teams that switched<br /><span class="text-gradient">never looked back</span></h2>
        </div>

        <div class="testimonials-grid">
          <div class="card testimonial-card" data-reveal data-delay="0">
            <div class="stars">★★★★★</div>
            <p class="testimonial-quote">"We moved from Jira and Notion juggling to Flowdesk in a week. Our standups went from 30 minutes to 10. I didn't think that was possible until we tried it."</p>
            <div class="testimonial-author">
              <div class="author-avatar" style="background: linear-gradient(135deg, #6366F1, #8B5CF6);">SL</div>
              <div>
                <div class="author-name">Sarah Lin</div>
                <div class="author-title">VP Engineering, Acecraft</div>
              </div>
            </div>
          </div>

          <div class="card testimonial-card" data-reveal data-delay="100">
            <div class="stars">★★★★★</div>
            <p class="testimonial-quote">"Flowdesk's timeline view alone was worth switching. Now every stakeholder can see exactly where a project stands without scheduling a meeting to explain it."</p>
            <div class="testimonial-author">
              <div class="author-avatar" style="background: linear-gradient(135deg, #0891B2, #06B6D4);">MK</div>
              <div>
                <div class="author-name">Marcus Köhler</div>
                <div class="author-title">Product Lead, Meridian</div>
              </div>
            </div>
          </div>

          <div class="card testimonial-card" data-reveal data-delay="200">
            <div class="stars">★★★★★</div>
            <p class="testimonial-quote">"The AI task breakdown is genuinely magical. I paste in a project brief and get a full task tree in seconds. My whole team uses it every sprint now."</p>
            <div class="testimonial-author">
              <div class="author-avatar" style="background: linear-gradient(135deg, #059669, #10B981);">AP</div>
              <div>
                <div class="author-name">Anita Patel</div>
                <div class="author-title">CTO, Stackwise</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ PRICING PREVIEW ============ -->
    <section class="section" id="pricing-preview">
      <div class="container">
        <div class="section-header centered" data-reveal>
          <span class="section-label">Simple pricing</span>
          <h2 class="section-title">Start free.<br /><span class="text-gradient">Scale as you grow.</span></h2>
          <p class="section-subtitle">No hidden fees, no per-seat surprises. All plans include unlimited projects.</p>
        </div>

        <div style="text-align:center; margin-bottom:var(--space-8);" data-reveal>
          <a href="pricing.html" class="btn btn-primary btn-lg">See all pricing plans →</a>
        </div>

        <div class="pricing-grid" data-reveal>
          <!-- Starter -->
          <div class="card pricing-card">
            <div class="plan-name">Starter</div>
            <div class="plan-price">
              <span class="price-currency" style="font-size:var(--text-2xl); margin-top:8px; color:var(--color-text-secondary);">$</span>
              <span class="price-amount" data-price-monthly="0" data-price-annual="0">0</span>
              <span class="price-period">/month</span>
            </div>
            <p class="plan-desc">Perfect for freelancers and small teams getting started with project management.</p>
            <ul class="plan-features">
              <li class="plan-feature"><span class="check-icon">✓</span> Up to 5 team members</li>
              <li class="plan-feature"><span class="check-icon">✓</span> 10 active projects</li>
              <li class="plan-feature"><span class="check-icon">✓</span> Basic task management</li>
              <li class="plan-feature"><span class="check-icon">✓</span> 5 GB storage</li>
              <li class="plan-feature"><span class="check-icon muted">✗</span><span style="color:var(--color-text-muted);">AI features</span></li>
            </ul>
            <a href="signup.html" class="btn btn-secondary btn-full">Get started free</a>
          </div>

          <!-- Pro (Popular) -->
          <div class="card pricing-card popular">
            <div class="popular-badge">Most Popular</div>
            <div class="plan-name">Pro</div>
            <div class="plan-price">
              <span class="price-currency" style="font-size:var(--text-2xl); margin-top:8px; color:var(--color-text-secondary);">$</span>
              <span class="price-amount" data-price-monthly="29" data-price-annual="23">29</span>
              <span class="price-period">/month</span>
            </div>
            <p class="plan-desc">For growing teams that need advanced features, more power, and integrations.</p>
            <ul class="plan-features">
              <li class="plan-feature"><span class="check-icon">✓</span> Up to 25 team members</li>
              <li class="plan-feature"><span class="check-icon">✓</span> Unlimited projects</li>
              <li class="plan-feature"><span class="check-icon">✓</span> AI task suggestions</li>
              <li class="plan-feature"><span class="check-icon">✓</span> Timeline &amp; Gantt views</li>
              <li class="plan-feature"><span class="check-icon">✓</span> 60+ integrations</li>
            </ul>
            <a href="signup.html" class="btn btn-primary btn-full">Start 14-day free trial</a>
          </div>

          <!-- Enterprise -->
          <div class="card pricing-card">
            <div class="plan-name">Enterprise</div>
            <div class="plan-price">
              <span class="price-amount">Custom</span>
            </div>
            <p class="plan-desc">For large organizations with complex needs, compliance requirements, and dedicated support.</p>
            <ul class="plan-features">
              <li class="plan-feature"><span class="check-icon">✓</span> Unlimited members</li>
              <li class="plan-feature"><span class="check-icon">✓</span> SSO &amp; SAML</li>
              <li class="plan-feature"><span class="check-icon">✓</span> SOC 2 Type II</li>
              <li class="plan-feature"><span class="check-icon">✓</span> Dedicated CSM</li>
              <li class="plan-feature"><span class="check-icon">✓</span> Custom SLA</li>
            </ul>
            <a href="contact.html" class="btn btn-secondary btn-full">Contact sales</a>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ FAQ ============ -->
    <section class="section bg-secondary">
      <div class="container">
        <div class="section-header centered" data-reveal>
          <span class="section-label">FAQ</span>
          <h2 class="section-title">Common questions</h2>
        </div>

        <div class="faq-list" data-reveal>
          <div class="faq-item open">
            <button class="faq-question">
              Is there really a free plan forever?
              <span class="faq-icon">+</span>
            </button>
            <div class="faq-answer">Yes. Our Starter plan is permanently free — no credit card required, no time limit. You get up to 5 team members, 10 projects, and core task management features. We believe teams should experience real value before committing.</div>
          </div>

          <div class="faq-item">
            <button class="faq-question">
              Can I import from Jira, Trello, or Asana?
              <span class="faq-icon">+</span>
            </button>
            <div class="faq-answer">Absolutely. Flowdesk has one-click importers for Jira, Trello, Asana, Monday.com, and CSV files. Most teams complete their full migration in under 30 minutes. Your data, history, and attachments all transfer cleanly.</div>
          </div>

          <div class="faq-item">
            <button class="faq-question">
              How does the 14-day trial work?
              <span class="faq-icon">+</span>
            </button>
            <div class="faq-answer">Sign up for any paid plan and get full access for 14 days at no charge. No credit card needed to start. At the end of the trial, you can subscribe or downgrade to the free plan — your data is always safe either way.</div>
          </div>

          <div class="faq-item">
            <button class="faq-question">
              What happens to my data if I cancel?
              <span class="faq-icon">+</span>
            </button>
            <div class="faq-answer">Your data stays accessible in a read-only archive for 30 days after cancellation, giving you time to export everything. We provide full JSON and CSV exports of all your projects, tasks, and comments at any time.</div>
          </div>

          <div class="faq-item">
            <button class="faq-question">
              Do you offer discounts for nonprofits or education?
              <span class="faq-icon">+</span>
            </button>
            <div class="faq-answer">Yes — verified nonprofits and educational institutions receive 50% off all paid plans. Reach out to our team via the contact page with documentation and we'll set you up within 24 hours.</div>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ CTA ============ -->
    <section class="section cta-section">
      <div class="cta-bg"></div>
      <div class="container">
        <div class="cta-box" data-reveal>
